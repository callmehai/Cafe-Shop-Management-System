{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npx tsc --noEmit)",
      "Bash(npx jest)",
      "Bash(npx jest:*)",
      "Bash(npx prisma generate)",
      "Bash(npx prisma validate)",
      "Bash(npm run lint)",
      "Bash(npm run build)",
      "Bash(npm test:*)",
      "Bash(flutter analyze)",
      "Bash(flutter test)",
      "Bash(flutter test:*)",
      "Bash(flutter pub get)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)"
    ],
    "ask": [
      "Bash(npx prisma migrate:*)",
      "Bash(npx prisma db push:*)",
      "Bash(npx prisma migrate reset:*)",
      "Bash(git push:*)",
      "Bash(git commit:*)"
    ]
  }
}
